# JVM options for Java 21 / development and low-scale production tasks
JAVA_OPTIONS=-Xms2048m -Xmx2048m -XX:MaxMetaspaceSize=512m -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/var/log/heap_dump/vahub_oom.hprof -server -Xlog:gc*:file=/var/log/gc/vahub_gc.log:time,tags:filecount=10,filesize=100m

# Possible JVM options for high-scale production tasks (just an example)
# JAVA_OPTIONS=-Xms4096m -Xmx4096m -XX:MaxMetaspaceSize=1024m -XX:+UseG1GC -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/var/log/heap_dump/vahub_oom.hprof -server -Xlog:gc*:file=/var/log/gc/vahub_gc.log:time,tags:filecount=10,filesize=100m
